# Copy this file to `.env` and do not commit the local `.env`.

# Optional. If omitted, triage.py uses local heuristic logic.
OPENAI_API_KEY=

# Model used when OPENAI_API_KEY is configured.
OPENAI_MODEL=gpt-4.1-mini

# Drafting defaults.
DEFAULT_REPLY_TONE=professional
MAX_DRAFT_WORDS=180

# Read-only IMAP ingestion. fetch_imap.py only reads unread messages.
# Supported providers: icloud, gmail, outlook, yahoo, aol, custom.
EMAIL_PROVIDER=icloud
# EMAIL_PROVIDER=gmail
# EMAIL_PROVIDER=outlook
# EMAIL_PROVIDER=yahoo
# EMAIL_PROVIDER=aol
# EMAIL_PROVIDER=custom

# IMAP_HOST is optional for known providers and required for EMAIL_PROVIDER=custom.
# Set it explicitly if you need to override the selected provider preset.
# IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USERNAME=your_icloud_email@example.com
IMAP_PASSWORD=your_app_specific_password
IMAP_MAILBOX=INBOX
IMAP_MAX_MESSAGES=5

# Optional. Overrides the local SQLite database path used by fetch_imap.py --save.
EMAIL_TRIAGE_DB_PATH=email_triage.db
