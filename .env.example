# Optional. If omitted, triage.py uses local heuristic logic.
OPENAI_API_KEY=

# Model used when OPENAI_API_KEY is configured.
OPENAI_MODEL=gpt-4.1-mini

# Drafting defaults.
DEFAULT_REPLY_TONE=professional
MAX_DRAFT_WORDS=180

# Read-only IMAP ingestion. fetch_imap.py only reads unread messages.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_MAX_MESSAGES=5
